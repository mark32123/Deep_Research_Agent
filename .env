# 替换成你自己的环境的IP和密钥BOCHA_API_KEY，这个搜索博查API登陆注册后获取
#DASHSCOPE_API_KEY在阿里云百炼获取
#MILVUS_HOST是部署的milvus的地址
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379
POSTGRES_DSN=postgresql://root:YOUR_POSTGRES_PASSWORD@YOUR_POSTGRES_HOST:5432/mydb
MILVUS_HOST=YOUR_MILVUS_HOST
MILVUS_PORT=19530
MILVUS_COLLECTION=mult_agent_memory
BOCHA_API_KEY=YOUR_BOCHA_API_KEY
